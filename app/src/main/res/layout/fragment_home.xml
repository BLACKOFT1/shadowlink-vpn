<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ══ CARTE COMPTE (invité ou connecté) ══ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Ligne principale : nom + badge plan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvAccountStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Mode invité" />

                    <TextView
                        android:id="@+id/tvPlan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_premium"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:text="PREMIUM"
                        android:textColor="@color/text_primary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Sous-titre : expiration ou invitation -->
                <TextView
                    android:id="@+id/tvAccountSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:text="Configs locales uniquement" />

                <!-- Temps reward -->
                <TextView
                    android:id="@+id/tvRewardTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <!-- Barre de données -->
                <ProgressBar
                    android:id="@+id/progressData"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="10dp"
                    android:progressTint="@color/accent_blue"
                    android:progressBackgroundTint="@color/divider"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvDataUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <!-- Bouton Se connecter / Mon compte -->
                <Button
                    android:id="@+id/btnAccountAction"
                    style="@style/BtnSecondary"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:text="SE CONNECTER AU PANEL"
                    android:textSize="12sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ CARTE SERVEUR ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="18dp"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/bg_card_elevated"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="34dp"
                    android:layout_height="24dp"
                    android:background="@color/divider"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvServerName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choisir un serveur"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/tvServerProtocol"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/accent_blue_light"
                            android:textSize="11sp"
                            android:text="—" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:text="  •  " />

                        <TextView
                            android:id="@+id/tvServerCountry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:text="—" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_nav_profiles"
                    android:alpha="0.4" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ STATUT + ANIMATION ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/animationView"
                android:layout_width="130dp"
                android:layout_height="130dp"
                app:lottie_rawRes="@raw/vpn_connecting"
                app:lottie_autoPlay="false"
                app:lottie_loop="true" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Déconnecté / Disconnected"
                android:textColor="@color/status_disconnected"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04" />
        </LinearLayout>

        <!-- ══ BOUTON CONNECT ══ -->
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="200dp"
            android:layout_height="54dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_button_connect"
            android:text="CONNECTER"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:layout_marginBottom="14dp" />

        <!-- ══ CARTE STATS (visible si connecté) ══ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/statsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:padding="14dp"
                android:useDefaultMargins="true">

                <LinearLayout android:orientation="vertical" android:gravity="center"
                    android:layout_columnWeight="1">
                    <TextView android:text="↑ Upload" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvUpload" android:textColor="@color/text_primary"
                        android:textSize="12sp" android:fontFamily="sans-serif-medium" android:text="0 B"/>
                </LinearLayout>

                <LinearLayout android:orientation="vertical" android:gravity="center"
                    android:layout_columnWeight="1">
                    <TextView android:text="↓ Download" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvDownload" android:textColor="@color/text_primary"
                        android:textSize="12sp" android:fontFamily="sans-serif-medium" android:text="0 B"/>
                </LinearLayout>

                <LinearLayout android:orientation="vertical" android:gravity="center"
                    android:layout_columnWeight="1">
                    <TextView android:text="⏱ Durée" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvDuration" android:textColor="@color/accent_cyan"
                        android:textSize="12sp" android:fontFamily="sans-serif-medium" android:text="00:00"/>
                </LinearLayout>

                <LinearLayout android:orientation="vertical" android:gravity="center"
                    android:layout_columnWeight="1">
                    <TextView android:text="📶 Ping" android:textColor="@color/text_secondary" android:textSize="10sp"/>
                    <TextView android:id="@+id/tvPing" android:textColor="@color/status_connected"
                        android:textSize="12sp" android:fontFamily="sans-serif-medium" android:text="--"/>
                </LinearLayout>

            </GridLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ BOUTON PUB → 1H GRATUITE (2 pubs de 30s) ══ -->
        <Button
            android:id="@+id/btnWatchAd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_card_accent"
            android:text="▶  Regarder 2 pubs (30s) → 1h de VPN gratuit"
            android:textColor="@color/accent_blue_light"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
